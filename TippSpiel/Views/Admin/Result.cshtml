@using TippSpiel.Helpers
@model TippSpiel.Models.Admin.AdminResultViewModel

@{
    ViewData["Title"] = "Ergebnis eintragen";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0" style="border-radius: 1rem; overflow: hidden;">
            
            <div class="card-header border-0 text-white py-3"
                 style="background-color: var(--bs-success-text-emphasis);">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-scoreboard-fill fs-4"></i>
                    <h2 class="h5 mb-0">Offizielles Ergebnis bestätigen</h2>
                </div>
            </div>

            <div class="card-body p-4">
                <form asp-action="Result" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input asp-for="Id" type="hidden" />

                    @* Das "Scoreboard" Display *@
                    <div class="d-flex justify-content-between align-items-center bg-light rounded-4 p-4 mb-4 border shadow-sm">
                        
                        @* Heimseite *@
                        <div class="text-center flex-grow-1">
                            <div class="mb-2">
                                <span class="fi @FlagHelper.GetFlagClass(Model.HomeTeam) fs-2 shadow-sm"></span>
                            </div>
                            <label asp-for="HomeTeamScore" class="fw-bold d-block mb-2 text-truncate">@Model.HomeTeam</label>
                            <input asp-for="HomeTeamScore" class="form-control form-control-lg text-center fw-bold mx-auto"
                                   type="number" min="0" style="max-width: 100px; border-radius: 0.8rem; font-family: monospace;" />
                            <span asp-validation-for="HomeTeamScore" class="text-danger small"></span>
                        </div>

                        <div class="px-3">
                            <span class="fs-1 fw-light text-muted">:</span>
                        </div>

                        @* Gastseite *@
                        <div class="text-center flex-grow-1">
                            <div class="mb-2">
                                <span class="fi @FlagHelper.GetFlagClass(Model.AwayTeam) fs-2 shadow-sm"></span>
                            </div>
                            <label asp-for="AwayTeamScore" class="fw-bold d-block mb-2 text-truncate">@Model.AwayTeam</label>
                            <input asp-for="AwayTeamScore" class="form-control form-control-lg text-center fw-bold mx-auto"
                                   type="number" min="0" style="max-width: 100px; border-radius: 0.8rem; font-family: monospace;" />
                            <span asp-validation-for="AwayTeamScore" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center mb-4" style="font-size: 0.85rem;">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <div>
                            Nach dem Speichern wird die Tabelle automatisch neu berechnet und die User-Punkte werden vergeben.
                        </div>
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">
                            <i class="bi bi-arrow-left"></i> Abbrechen
                        </a>
                        <button type="submit" class="btn btn-lg px-4 text-white shadow-sm"
                                style="background-color: var(--bs-success-text-emphasis); border-radius: 0.6rem;">
                            <i class="bi bi-check-circle-fill me-1"></i> Ergebnis speichern
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}