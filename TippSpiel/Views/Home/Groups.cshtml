@model IReadOnlyList<TippSpiel.Models.ViewModels.GroupOverviewViewModel>

@{
    ViewData["Title"] = "Gruppenübersicht";
}

<h1>Gruppenübersicht</h1>

@if (Model.Count == 0)
{
    <p>Noch keine Gruppen vorhanden.</p>
}
else
{
    @foreach (var group in Model)
    {
        <section class="mb-5">
            <h2>Gruppe @group.GroupName</h2>

            <h3>Tabelle</h3>
            @if (group.TableRows.Count > 0)
            {
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Platz</th>
                            <th>Team</th>
                            <th>Sp</th>
                            <th>W</th>
                            <th>D</th>
                            <th>L</th>
                            <th>Tore</th>
                            <th>Diff</th>
                            <th>Pkt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in group.TableRows)
                        {
                            var highlightClass = row.Position <= 2 ? "table-success" : "";

                            <tr class="@highlightClass">
                                <td>@row.Position</td>
                                <td>@row.TeamName</td>
                                <td>@row.GamesPlayed</td>
                                <td>@row.Wins</td>
                                <td>@row.Draws</td>
                                <td>@row.Losses</td>
                                <td>@row.GoalsFor:@row.GoalsAgainst</td>
                                <td>@row.GoalDifference</td>
                                <td>@row.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Keine Tabelle verfügbar.</p>
            }

            <h3>Spiele</h3>
            @if (group.Games.Count > 0)
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Kickoff</th>
                            <th>Heim</th>
                            <th>Gast</th>
                            <th>Ergebnis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in group.Games)
                        {
                            <tr>
                                <td>@(game.KickOff == default ? "-" : game.KickOff.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td>
                                <td>@game.HomeTeam</td>
                                <td>@game.AwayTeam</td>
                                <td>
                                    @if (game.HomeTeamScore.HasValue && game.AwayTeamScore.HasValue)
                                    {
                                        @($"{game.HomeTeamScore}:{game.AwayTeamScore}")
                                    }
                                    else
                                    {
                                        @:-
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>Keine Spiele eingetragen.</p>
            }
        </section>
    }
}