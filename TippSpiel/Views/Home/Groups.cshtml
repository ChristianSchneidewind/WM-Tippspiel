@model IReadOnlyList<TippSpiel.Models.ViewModels.GroupOverviewViewModel>
@{
    ViewData["Title"] = "Gruppenübersicht";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6">Gruppenübersicht</h1>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Noch keine Gruppen vorhanden.</div>
}
else
{
    <div class="row g-4">
        @foreach (var group in Model)
        {
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <strong>Gruppe @group.GroupName</strong>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="fw-semibold mb-2">Teams</div>
                            @if (group.Teams.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var team in group.Teams)
                                    {
                                        <span class="badge bg-primary">@team</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">Keine Teams gefunden.</div>
                            }
                        </div>
                        <div>
                            <div class="fw-semibold mb-2">Spiele</div>
                            @if (group.Games.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Kickoff</th>
                                                <th>Heim</th>
                                                <th>Gast</th>
                                                <th class="text-center">Ergebnis</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var game in group.Games)
                                            {
                                                <tr>
                                                    <td>@(game.KickOff == default ? "-" : game.KickOff.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))</td>
                                                    <td>@game.HomeTeam</td>
                                                    <td>@game.AwayTeam</td>
                                                    <td class="text-center">
                                                        @if (game.HomeTeamScore.HasValue && game.AwayTeamScore.HasValue)
                                                        {
                                                            <span>@game.HomeTeamScore : @game.AwayTeamScore</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">Keine Spiele eingetragen.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

}
