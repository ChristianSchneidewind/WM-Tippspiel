@model TippSpiel.Models.ViewModels.RankingsViewModel
@{
    ViewData["Title"] = "Tipps & Rankings";
}

<h1 class="display-6 mb-4">Tipps & Rankings</h1>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-info">Noch keine Tipps oder Nutzer vorhanden.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th class="text-end">Punkte</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Entries.Count; i++)
                {
                    var entry = Model.Entries[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@entry.UserName</td>
                        <td class="text-end">@entry.Points</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
