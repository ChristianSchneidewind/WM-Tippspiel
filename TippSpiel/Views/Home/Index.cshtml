@model TippSpiel.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Start";
}

<div class="text-center mb-5">
    <h1 class="display-5">WM Tippspiel 2026</h1>
    <p class="lead">Übersicht über Gruppen, Spielplan und Rankings.</p>
</div>

@if (Model.NextGame != null)
{
    <div class="alert alert-info d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div>
            <strong>Nächstes Spiel:</strong> @Model.NextGame.HomeTeam vs. @Model.NextGame.AwayTeam
            @if (!string.IsNullOrWhiteSpace(Model.NextGame.GroupName))
            {
                <span class="ms-2 badge bg-secondary">Gruppe @Model.NextGame.GroupName</span>
            }
        </div>
        <div class="mt-2 mt-md-0">
            @(Model.NextGame.KickOff == default ? "Datum folgt" : Model.NextGame.KickOff.ToLocalTime().ToString("dd.MM.yyyy HH:mm"))
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-12 col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title">Gruppenübersicht</h5>
                    <span class="badge rounded-pill bg-primary">@Model.GroupCount</span>
                </div>
                <p class="card-text">Alle Gruppen mit Teams und Ergebnissen.</p>
                <a class="btn btn-primary" asp-controller="Home" asp-action="Groups">Zur Übersicht</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title">Spielplan</h5>
                    <span class="badge rounded-pill bg-primary">@Model.GameCount</span>
                </div>
                <p class="card-text">Alle Spiele nach Datum sortiert.</p>
                <a class="btn btn-primary" asp-controller="Home" asp-action="Schedule">Zum Spielplan</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title">Tipps & Rankings</h5>
                    <span class="badge rounded-pill bg-primary">@Model.TippCount</span>
                </div>
                <p class="card-text">Aktueller Punktestand aller Teilnehmer.</p>
                <a class="btn btn-primary" asp-controller="Home" asp-action="Rankings">Zu den Rankings</a>
            </div>
        </div>
    </div>
</div>
