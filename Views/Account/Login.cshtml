@model TippSpiel.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Anmelden";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">

            <div class="card shadow border-0" style="border-radius: 1rem; overflow: hidden;">

                <div class="card-header border-0 text-white text-center py-4" style="background-color: #0c2b18;">
                    <h2 class="h4 mb-0">Willkommen zurück!</h2>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        @* Benutzername *@
                        <label asp-for="UserName" class="form-label fw-bold small text-muted text-uppercase">Benutzername</label>
                        <div class="input-group mb-3 custom-input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-person-fill"></i></span>
                            <input asp-for="UserName" class="form-control border-0 shadow-none bg-light" placeholder="Username" autofocus />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>

                        @* Passwort *@
                        <label asp-for="Password" class="form-label fw-bold small text-muted text-uppercase">Passwort</label>
                        <div class="input-group mb-3 custom-input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-key-fill"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-0 shadow-none bg-light" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small text-muted">
                                Angemeldet bleiben
                            </label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-lg text-white shadow-sm fw-bold" style="background-color: #0c2b18; border-radius: 0.5rem;">
                                Anmelden
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light border-0 py-3 text-center">
                    <span class="text-muted small">Neu hier?</span>
                    <a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none ms-1" style="color: #0c2b18;">
                        Registrieren
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Das Geheimnis: Der Rahmen liegt auf der Group, nicht auf dem Input */
    .custom-input-group {
        border: 1px solid #ced4da;
        border-radius: 0.5rem;
        transition: all 0.2s ease-in-out;
        overflow: hidden;
    }

        /* Wenn man ins Feld klickt, leuchtet die ganze Group grün */
        .custom-input-group:focus-within {
            border-color: #0c2b18 !important;
            box-shadow: 0 0 0 0.25rem rgba(12, 43, 24, 0.15);
            background-color: #fff !important;
        }

        /* Das eigentliche Input-Feld darf keinen eigenen Rahmen/Schatten haben */
        .custom-input-group .form-control:focus {
            background-color: #fff !important;
        }

    .input-group-text {
        color: #6c757d;
        font-size: 1.1rem;
    }

    .btn:hover {
        filter: brightness(1.2);
        transition: 0.3s;
    }
</style>