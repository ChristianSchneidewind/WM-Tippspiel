@model TippSpiel.Models.ViewModels.StatisticsIndexViewModel

@{
    ViewData["Title"] = "Statistiken";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-title-container">
    <h1 class="display-6 page-title">Statistiken</h1>
</div>

<!-- Erste Reihe -->
<div class="row g-4">

    <!-- Top-Torschützen -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-white"
                 style="background-color: var(--bs-success-text-emphasis);">
                <strong>Top-Torschützen</strong>
            </div>

            <div class="card-body">
                @if (!Model.TopScorers.Any())
                {
                    <div class="text-muted">Noch keine Torschützen vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Spieler</th>
                                <th>Team</th>
                                <th class="text-center">Tore</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var player in Model.TopScorers)
                            {
                                <tr>
                                    <td class="fw-bold">@player.PlayerName</td>
                                    <td>@player.TeamName</td>

                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill">
                                            @player.Count
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Top-Vorlagen -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-white"
                 style="background-color: var(--bs-success-text-emphasis);">
                <strong>Top-Vorlagen</strong>
            </div>

            <div class="card-body">
                @if (!Model.TopAssists.Any())
                {
                    <div class="text-muted">Noch keine Vorlagen vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Spieler</th>
                                <th>Team</th>
                                <th class="text-center">Vorlagen</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var player in Model.TopAssists)
                            {
                                <tr>
                                    <td class="fw-bold">@player.PlayerName</td>
                                    <td>@player.TeamName</td>

                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill">
                                            @player.Count
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

<!-- Zweite Reihe -->
<div class="row g-4 mt-1">

    <!-- Gelbe Karten -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-dark bg-warning">
                <strong>Gelbe Karten</strong>
            </div>

            <div class="card-body">
                @if (!Model.YellowCards.Any())
                {
                    <div class="text-muted">Noch keine gelben Karten vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Spieler</th>
                                <th>Team</th>
                                <th class="text-center">Gelbe Karten</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var player in Model.YellowCards)
                            {
                                <tr>
                                    <td class="fw-bold">@player.PlayerName</td>
                                    <td>@player.TeamName</td>

                                    <td class="text-center">
                                        <span class="badge bg-warning text-dark rounded-pill">
                                            @player.Count
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Rote Karten -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-white bg-danger">
                <strong>Rote Karten</strong>
            </div>

            <div class="card-body">
                @if (!Model.RedCards.Any())
                {
                    <div class="text-muted">Noch keine roten Karten vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Spieler</th>
                                <th>Team</th>
                                <th class="text-center">Rote Karten</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var player in Model.RedCards)
                            {
                                <tr>
                                    <td class="fw-bold">@player.PlayerName</td>
                                    <td>@player.TeamName</td>

                                    <td class="text-center">
                                        <span class="badge bg-danger rounded-pill">
                                            @player.Count
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>

<div class="row g-4 mt-1">

    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-white bg-success">
                <strong>Fairste Mannschaften</strong>
            </div>

            <div class="card-body">
                @if (!Model.FairestTeams.Any())
                {
                    <div class="text-muted">Noch keine Fairplay-Daten vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Team</th>
                                <th class="text-center">Gelb</th>
                                <th class="text-center">Rot</th>
                                <th class="text-center">Fairplay-Punkte</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var team in Model.FairestTeams)
                            {
                                <tr>
                                    <td class="fw-bold">@team.TeamName</td>
                                    <td class="text-center">@team.YellowCards</td>
                                    <td class="text-center">@team.RedCards</td>
                                    <td class="text-center">
                                        <span class="badge bg-success rounded-pill">@team.FairplayPoints</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header text-white bg-danger">
                <strong>Unfairste Mannschaften</strong>
            </div>

            <div class="card-body">
                @if (!Model.UnfairestTeams.Any())
                {
                    <div class="text-muted">Noch keine Fairplay-Daten vorhanden.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Team</th>
                                <th class="text-center">Gelb</th>
                                <th class="text-center">Rot</th>
                                <th class="text-center">Fairplay-Punkte</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var team in Model.UnfairestTeams)
                            {
                                <tr>
                                    <td class="fw-bold">@team.TeamName</td>
                                    <td class="text-center">@team.YellowCards</td>
                                    <td class="text-center">@team.RedCards</td>
                                    <td class="text-center">
                                        <span class="badge bg-danger rounded-pill">@team.FairplayPoints</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</div>