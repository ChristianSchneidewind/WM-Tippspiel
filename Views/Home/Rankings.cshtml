@model TippSpiel.Models.ViewModels.RankingsViewModel
@{
    ViewData["Title"] = "Tipps & Rankings";
}

<style>
    .ranking-card {
        border-radius: 1.5rem;
        border: none;
        overflow: hidden;
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1);
    }

    .table-hover-custom tbody tr:hover {
        filter: brightness(0.97);
        transition: background-color 0.2s;
    }

    /* Top 3 Stylings */
    .rank-1 {
        background-color: #fff9c4 !important;
    }
    /* Gold-Hauch */
    .rank-2 {
        background-color: #f5f5f5 !important;
    }
    /* Silber-Hauch */
    .rank-3 {
        background-color: #fff3e0 !important;
    }
    /* Bronze-Hauch */

    .medal-icon {
        font-size: 1.2rem;
    }

    .points-badge {
        background-color: var(--bs-success-text-emphasis);
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 50rem;
        font-weight: bold;
        min-width: 50px;
        display: inline-block;
        text-align: center;
    }

    .custom-border-green {
        border-color: var(--bs-success-border-subtle) !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4 page-title-container">
    <h1 class="display-6 page-title">Tipps & Rankings</h1>
</div>

@* Logo-Bereich mit sanfter Animation *@
<div class="mb-5 d-flex justify-content-center align-items-center">
    <img src="/Images/pokalalternative_wobg.png"
         alt="Pokal"
         class="img-fluid floating-animation"
         style="max-width: 280px; height: auto;"
         onerror="this.style.display='none';">
</div>

@if (Model.Entries.Count == 0)
{
    <div class="card bg-light border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-person-exclamation display-4 d-block mb-3 opacity-50"></i>
            Noch keine Tipps oder Nutzer vorhanden.
        </div>
    </div>
}
else
{
    <div class="card ranking-card">
        @* Header im bekannten Dunkelgrün *@
        <div class="card-header border-0 text-white d-flex justify-content-between align-items-center py-3"
             style="background-color: var(--bs-success-text-emphasis);">
            <strong class="fs-4">Bestenliste</strong>
            <i class="bi bi-bar-chart-line-fill"></i>
        </div>

        <div class="card-body p-4">
            <div class="table-responsive rounded shadow-sm border border-2 custom-border-green">
                <table class="table table-hover-custom align-middle mb-0">
                    <thead style="background-color: #f8f9fa;">
                        <tr class="small text-uppercase tracking-wider text-muted">
                            <th class="ps-4" style="width: 80px;">Rang</th>
                            <th>Teilnehmer</th>
                            <th class="text-center" style="width: 150px;">Punkte</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Entries.Count; i++)
                        {
                            var entry = Model.Entries[i];
                            var rank = i + 1;
                            var rowClass = rank switch
                            {
                                1 => "rank-1",
                                2 => "rank-2",
                                3 => "rank-3",
                                _ => ""
                            };

                            <tr class="@rowClass">
                                <td class="ps-4 fw-bold">
                                    @if (rank <= 3)
                                    {
                                        <span class="medal-icon">
                                            @(rank == 1 ? "🥇" : rank == 2 ? "🥈" : "🥉")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="ms-1 text-muted">#@rank</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-placeholder me-3 d-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm border"
                                             style="width: 35px; height: 35px; font-size: 0.8rem; color: var(--bs-success-text-emphasis);">
                                            @entry.UserName.Substring(0, Math.Min(2, entry.UserName.Length)).ToUpper()
                                        </div>
                                        <span class="fw-bold text-dark">@entry.UserName</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="points-badge shadow-sm">
                                        @entry.Points
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
