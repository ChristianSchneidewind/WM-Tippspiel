@using TippSpiel.Helpers
@model IReadOnlyList<TippSpiel.Models.ViewModels.GroupOverviewViewModel>
@{
    ViewData["Title"] = "Gruppenübersicht";
}

<style>
    .result-badge {
        font-family: monospace;
        font-size: 0.9rem;
        padding: 0.4rem 0.8rem;
        min-width: 65px;
        display: inline-block;
        line-height: 1.2;
        text-align: center;
        border-radius: 0.375rem;
    }

    .table-hover-custom tbody tr:hover {
        filter: brightness(0.95);
        transition: filter 0.2s;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
    }

    .custom-border-green {
        border-color: var(--bs-success-border-subtle) !important;
    }

    .align-header-middle th {
        vertical-align: middle !important;
        height: 55px;
    }

    /* Verhindert Zeilenumbruch bei Spielorten */
    .nowrap-column {
        white-space: nowrap;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4 page-title-container">
    <h1 class="display-6 page-title">Gruppenübersicht</h1>
</div>

@if (!Model.Any())
{
    <div class="card bg-light border-0 shadow-sm">
        <div class="card-body text-center text-muted">Noch keine Gruppen vorhanden.</div>
    </div>
}
else
{
    <div class="row g-5">
        @foreach (var group in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm border-0 overflow-hidden mb-4" style="border-radius: 1rem;">

                    @* Header *@
                    <div class="card-header border-0 text-white d-flex justify-content-between align-items-center py-3"
                         style="background-color: var(--bs-success-text-emphasis);">
                        <strong class="fs-4">@group.GroupName</strong>
                        <i class="bi bi-table"></i>
                    </div>

                    <div class="card-body p-4">

                        @* OBEN: Teilnehmer & Tabelle *@
                        <div class="row g-4 mb-5">

                            @* Teilnehmer *@
                            <div class="col-lg-4">
                                <div class="fw-bold mb-3 small text-uppercase tracking-wider text-success-emphasis">Teilnehmer</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var team in group.Teams)
                                    {
                                        <a asp-controller="Teams"
                                           asp-action="Details"
                                           asp-route-id="@team.Id"
                                           asp-route-source="groups"
                                           class="badge rounded-pill px-3 py-2 fw-medium shadow-sm text-decoration-none"
                                           style="background-color: var(--bs-success-text-emphasis); font-size: 0.85rem;">
                                            <span class="fi @FlagHelper.GetFlagClass(team.Name) me-1"></span>
                                            @GameHelper.FixTeamName(team.Name)
                                            <i class="bi bi-arrow-right-short ms-1"></i>
                                        </a>
                                    }
                                </div>
                            </div>

                            @* Tabelle *@
                            <div class="col-lg-8">
                                <div class="fw-bold mb-2 small text-uppercase tracking-wider text-success-emphasis">Tabelle</div>
                                @if (group.TableRows?.Any() == true)
                                {
                                    <div class="table-responsive rounded shadow-sm border border-2 custom-border-green">
                                        <table class="table table-sm table-striped align-middle mb-0">
                                            <thead class="table-light align-header-middle">
                                                <tr class="small text-muted border-bottom">
                                                    <th class="ps-3" style="width: 50px;">#</th>
                                                    <th>TEAM</th>
                                                    <th class="text-center">SP</th>
                                                    <th class="text-center">T</th>
                                                    <th class="text-center">TD</th>
                                                    <th class="text-center">PKT</th>
                                                </tr>
                                            </thead>
                                            <tbody class="small">
                                                @foreach (var row in group.TableRows.OrderBy(r => r.Position))
                                                {
                                                    var rowClass = row.Position switch { <= 2 => "table-success", 3 => "table-warning", _ => "" };
                                                    <tr class="@rowClass">
                                                        <td class="fw-bold ps-3">@row.Position</td>
                                                        <td class="fw-bold text-dark">
                                                            <span class="fi @FlagHelper.GetFlagClass(row.TeamName) me-1"></span> @row.TeamName
                                                        </td>
                                                        <td class="text-center">@row.GamesPlayed</td>
                                                        <td class="text-center">@row.GoalsFor:@row.GoalsAgainst</td>
                                                        <td class="text-center">@(row.GoalsFor - row.GoalsAgainst)</td>
                                                        <td class="text-center fw-bold">@row.Points</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>

                        @* UNTEN: Spielplan *@
                        <div class="row">
                            <div class="col-12">
                                <div class="fw-bold mb-2 small text-uppercase tracking-wider text-success-emphasis">Gruppenspielplan</div>
                                @if (group.Games?.Any() == true)
                                {
                                    <div class="table-responsive rounded shadow-sm border border-2 custom-border-green">
                                        <table class="table table-success table-striped table-hover-custom align-middle mb-0"
                                               style="--bs-table-striped-bg: #c8e6c9; --bs-table-bg: #e8f5e9;">
                                            <thead class="align-header-middle" style="background-color: var(--bs-success-text-emphasis);">
                                                <tr class="small text-white">
                                                    <th class="ps-3" style="width: 70px;">MATCH</th>
                                                    <th style="width: 110px;">TERMIN</th>
                                                    <th class="nowrap-column" style="width: 220px;">ORT</th>
                                                    <th class="text-center">PARTIE</th>
                                                    <th class="text-center" style="width: 130px;">ERGEBNIS</th>
                                                </tr>
                                            </thead>
                                            <tbody class="small">
                                                @foreach (var game in group.Games.OrderBy(g => g.KickOff))
                                                {
                                                    <tr class="border-bottom border-black border-opacity-10">
                                                        <td class="ps-3 fw-bold text-success" style="color: #1b5e20 !important;">
                                                            #@(game.MatchNumber?.ToString() ?? "-")
                                                        </td>
                                                        <td class="fw-bold text-dark">
                                                            @(game.KickOff == default ? "-" : game.KickOff.ToLocalTime().ToString("dd.MM. HH:mm"))
                                                        </td>
                                                        <td class="text-dark nowrap-column">
                                                            <i class="bi bi-geo-alt small opacity-50 me-1"></i> @(game.Venue ?? "-")
                                                        </td>
                                                        <td>
                                                            <div class="d-flex align-items-center justify-content-center w-100">
                                                                <div class="text-end d-flex align-items-center justify-content-end" style="flex: 1;">
                                                                    <span class="fw-bold text-dark">@GameHelper.FixTeamName(game.HomeTeamName)</span>
                                                                    <span class="fi @FlagHelper.GetFlagClass(game.HomeTeamName) ms-2 shadow-sm"></span>
                                                                </div>
                                                                <div class="text-dark opacity-50 fw-light text-center small mx-2" style="width: 25px;">vs.</div>
                                                                <div class="text-start d-flex align-items-center justify-content-start" style="flex: 1;">
                                                                    <span class="fi @FlagHelper.GetFlagClass(game.AwayTeamName) me-2 shadow-sm"></span>
                                                                    <span class="fw-bold text-dark">@GameHelper.FixTeamName(game.AwayTeamName)</span>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td class="text-center">
                                                            @if (game.HomeTeamScore.HasValue)
                                                            {
                                                                <span class="result-badge text-white shadow-sm" style="background-color: #1b5e20;">
                                                                    @game.HomeTeamScore : @game.AwayTeamScore
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="result-badge bg-white text-dark border border-success-subtle shadow-sm opacity-75">
                                                                    - : -
                                                                </span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}