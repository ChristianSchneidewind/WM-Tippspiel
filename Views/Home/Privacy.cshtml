@{
    ViewData["Title"] = "Datenschutz";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-sm border-0" style="border-radius: 1rem; overflow: hidden;">
            
            <div class="card-header border-0 text-white py-3"
                 style="background-color: var(--bs-success-text-emphasis);">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check fs-4"></i>
                    <h2 class="h5 mb-0">Datenschutz & Fairplay</h2>
                </div>
            </div>

            <div class="card-body p-4 p-md-5">
                <section class="mb-4">
                    <h3 class="h5 fw-bold text-success-emphasis">1. Datenminimierung</h3>
                    <p class="text-muted">
                        Bei uns gilt Fairplay: Wir speichern nur das, was für den Spielbetrieb notwendig ist.
                        Dazu gehören dein gewählter <strong>Benutzername</strong>, deine <strong>E-Mail-Adresse</strong>
                        (für die Anmeldung) und natürlich deine <strong>Tipps</strong>.
                    </p>
                </section>

                <section class="mb-4">
                    <h3 class="h5 fw-bold text-success-emphasis">2. Speicherung & Sicherheit</h3>
                    <p class="text-muted">
                        Deine Passwörter werden sicher verschlüsselt in unserer Datenbank gespeichert.
                        Nur Administratoren haben Zugriff auf die Systemverwaltung, um einen reibungslosen
                        Turnierablauf zu garantieren.
                    </p>
                </section>

                <section class="mb-4">
                    <h3 class="h5 fw-bold text-success-emphasis">3. Cookies</h3>
                    <p class="text-muted">
                        Wir nutzen lediglich notwendige "Session-Cookies", um dich während deines Besuchs
                        angemeldet zu halten. Es findet kein Tracking durch Drittanbieter statt.
                    </p>
                </section>

                <section class="mb-0">
                    <h3 class="h5 fw-bold text-success-emphasis">4. Deine Rechte</h3>
                    <p class="text-muted">
                        Du kannst jederzeit verlangen, dass dein Account und alle deine Tipps gelöscht werden.
                        Wende dich dazu einfach an das Admin-Team.
                    </p>
                </section>

                <hr class="my-4 opacity-25">

                <div class="text-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success rounded-pill px-4">
                        <i class="bi bi-arrow-left me-1"></i> Zurück zum Spiel
                    </a>
                </div>
            </div>
        </div>

        <div class="text-center mt-4 mb-5">
            <small class="text-muted">Stand: WM 2026 Vorbereitung</small>
        </div>
    </div>
</div>